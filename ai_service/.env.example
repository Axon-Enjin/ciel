# Ciel AI Service Environment Variables
# Copy this file to .env and fill in your actual values

# Environment
ENVIRONMENT=development

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Microsoft Foundry Configuration
# Get these from: https://portal.azure.com
FOUNDRY_ENDPOINT=your_foundry_endpoint_here
FOUNDRY_API_KEY=your_foundry_api_key_here
FOUNDRY_DEPLOYMENT_SONNET=claude-sonnet-3-5
FOUNDRY_DEPLOYMENT_OPUS=claude-opus-3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Token Budget (per SDD §8)
MAX_TOKENS_TOC_GENERATION=12000
MAX_TOKENS_CRITIQUE=10000
MAX_TOKENS_GRANT_SECTION=6000

# Feature Flags
ENABLE_TOC_CRITIQUE=true
ENABLE_STREAMING=true

# Logging
LOG_LEVEL=INFO

# Client proxy (set in client/.env.local as AI_SERVICE_URL=http://localhost:8000)
